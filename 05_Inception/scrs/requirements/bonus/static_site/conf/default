server {
    listen 80;
    listen [::]:80;

    server_name static_site;

    root /var/www/html;
    index index.html;

    location / {
        try_files $uri $uri/ =404;
    }

    location ~* \.(js|css|png|jpg|jpeg|gif|ico)$ {
        expires max;
        log_not_found off;
    }

	location /api/models {
        proxy_pass http://ollama-ai:11434/api/tags;
        proxy_set_header Host $host;
    }
}
